# Windows system files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# macOS system files (if anyone edits on Mac)
.DS_Store
.AppleDouble
.LSOverride

# Editor temporary / backup files
*~
*.swp
*.swo
.vscode/
.idea/

# Node / build artifacts (in case anyone adds tooling later)
node_modules/
dist/
build/
.env
.env.local

# OS junk
*.log

# Backup files — never commit working-state backups to the deploy repo
*.backup
*.backup-*
*.bak
*.orig
*-before-*.html
*-before-*.js
*-before-*.json

# Cloudflare Worker config — belongs in the Worker repo, not the static site repo
wrangler.toml
wrangler.jsonc
.wrangler/
.dev.vars
